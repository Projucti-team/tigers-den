{
  "name": "tigersden",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --webpack",
    "build:docker": "npm run generate:importmap && npm run build",
    "deploy:cricket-sync": "npx tsx scripts/run-deploy-cricket-sync.ts",
    "build:prod": "payload generate:importmap && next build",
    "start": "next start",
    "lint": "next lint",
    "payload": "payload",
    "generate:types": "payload generate:types",
    "generate:importmap": "payload generate:importmap",
    "scrape:icc-rankings": "tsx scripts/scrape-icc-rankings.ts",
    "scrape:wtc-standings": "tsx scripts/scrape-wtc-standings.ts",
    "scrape:bangladesh-match": "tsx scripts/scrape-bangladesh-match.ts",
    "scrape:bangladesh-news": "tsx scripts/scrape-bangladesh-news.ts",
    "scrape:espn-squads": "tsx scripts/scrape-espn-squads.ts",
    "sync:cricket": "tsx scripts/sync-cricket-nightly.ts",
    "sync:cricket:prod": "bash scripts/prod-cricket-sync.sh",
    "rebuild:rankings": "tsx scripts/rebuild-rankings-showcase.ts",
    "generate:logo": "python3 scripts/process-tigers-den-logo.py"
  },
  "dependencies": {
    "@payloadcms/db-sqlite": "3.84.1",
    "@payloadcms/next": "3.84.1",
    "@payloadcms/richtext-lexical": "3.84.1",
    "@payloadcms/ui": "3.84.1",
    "graphql": "^16.10.0",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.30",
    "payload": "3.84.1",
    "pg": "^8.16.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/node": "^22.15.21",
    "@types/pg": "^8.15.6",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.28.0",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
