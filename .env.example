# Payload CMS
PAYLOAD_SECRET=change-me-to-a-long-random-string

# Local dev + production: SQLite (persisted volume on Coolify/VPS).
DATABASE_URI=file:./tigersden.db

# Public site URL (must match where you open /admin — use http://localhost:3000 locally)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Member sign-in (Google + Facebook) — https://authjs.dev
AUTH_SECRET=generate-with-openssl-rand-base64-32
# Google Cloud → OAuth client (Web) → Authorized redirect URIs:
#   http://localhost:3000/api/auth/callback/google
#   https://tigersden.bd/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Meta app → Facebook Login → Settings → Valid OAuth Redirect URIs:
#   http://localhost:3000/api/auth/callback/facebook
#   https://YOUR_DOMAIN/api/auth/callback/facebook
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Cricket data (see docs/cricket-api.md) — CricAPI key for /tours index only; tour detail pages use ESPN snapshots from nightly sync
CRICKET_DATA_API_KEY=
# Optional second cricketdata.org account key — used automatically when the primary hits its daily quota
CRICKET_DATA_API_KEY_FALLBACK=
# Optional third account key — rotated after the first fallback is exhausted
CRICKET_DATA_API_KEY_FALLBACK_2=

# Secures GET /api/cron/cricket (Coolify schedule sends Authorization: Bearer …)
CRON_SECRET=generate-with-openssl-rand-base64-32

# The Roar live chat (Firebase Firestore — real-time, not Postgres)
# Firebase console → Project settings → Your apps → Web app (public keys)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Firebase console → Project settings → Service accounts → Generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste private key with literal \n line breaks (or wrap in quotes in Coolify)
FIREBASE_PRIVATE_KEY=

# Deployment: docs/deploy-coolify.md | docs/deploy-production.md
