# Payload CMS
PAYLOAD_SECRET=change-me-to-a-long-random-string

# Local dev + production: SQLite (persisted volume on Coolify/VPS).
DATABASE_URI=file:./tigersden.db

# Public site URL (must match where you open /admin — use http://localhost:3000 locally)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Member sign-in (Google + Facebook) — https://authjs.dev
AUTH_SECRET=generate-with-openssl-rand-base64-32
# Google Cloud → OAuth client (Web) → Authorized redirect URIs:
#   http://localhost:3000/api/auth/callback/google
#   https://tigersden.bd/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Meta app → Facebook Login → Settings → Valid OAuth Redirect URIs:
#   http://localhost:3000/api/auth/callback/facebook
#   https://YOUR_DOMAIN/api/auth/callback/facebook
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Cricket data (see docs/cricket-api.md) — optional, free tier ~100 req/day
CRICKET_DATA_API_KEY=
# Optional second cricketdata.org account key — used automatically when the primary hits its daily quota
CRICKET_DATA_API_KEY_FALLBACK=

# Secures GET /api/cron/cricket (Coolify schedule sends Authorization: Bearer …)
CRON_SECRET=generate-with-openssl-rand-base64-32

# Deployment: docs/deploy-coolify.md | docs/deploy-production.md
