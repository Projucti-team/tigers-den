# Payload CMS
PAYLOAD_SECRET=change-me-to-a-long-random-string

# Local dev: SQLite (default). Production on Vercel uses Neon via POSTGRES_URL.
DATABASE_URI=file:./tigersden.db

# Set by Vercel when you add Neon Postgres (not needed locally)
# POSTGRES_URL=

# Set by Vercel when you add Blob storage (not needed locally)
# BLOB_READ_WRITE_TOKEN=

# Public site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Cricket data (see docs/cricket-api.md) — optional, free tier ~100 req/day
CRICKET_DATA_API_KEY=

# Free deploy: docs/deploy-free.md | VPS: docs/deploy-production.md
