# VPS/Docker / Coolify — see docs/deploy-coolify.md and docs/deploy-production.md

PAYLOAD_SECRET=
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_SERVER_URL=https://your-domain.com
# Runtime fallback on Docker/Coolify when NEXT_PUBLIC_* was not set at build time:
SERVER_URL=https://your-domain.com

# Production (recommended): Postgres on the same server as the app (Coolify DB resource).
# Use the internal Docker URL, e.g. postgresql://user:pass@postgres-xxx:5432/tigersden
POSTGRES_URL=

# Do NOT set DATABASE_URI=file:... when POSTGRES_URL is set.
# Local dev only:
# DATABASE_URI=file:./tigersden.db

CRICKET_DATA_API_KEY=
# Optional second cricketdata.org account key — used automatically when the primary hits its daily quota
CRICKET_DATA_API_KEY_FALLBACK=
# Protects /api/cron/cricket and /api/admin/bootstrap-db — run: openssl rand -base64 32
CRON_SECRET=
# 1 = sync after each deploy if tours missing (Coolify default). 0 = off. force = always sync
CRICKET_SYNC_ON_START=1
AUTH_SECRET=
# Google Cloud → OAuth client (Web) → Authorized redirect URIs:
#   https://tigersden.bd/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Meta app → Facebook Login → Valid OAuth Redirect URIs: https://your-domain.com/api/auth/callback/facebook
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
# DOMAIN=your-domain.com

# Migrating off Neon: docs/migrate-neon-to-server-postgres.md

# The Roar live chat — Firebase Firestore (real-time). See docs/firebase-chat.md
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
