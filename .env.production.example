# VPS/Docker (Hetzner etc.) — see docs/deploy-production.md

PAYLOAD_SECRET=
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_SERVER_URL=https://your-domain.com
DATABASE_URI=file:/app/data/tigersden.db
CRICKET_DATA_API_KEY=
# Protects /api/cron/cricket and /api/admin/bootstrap-db — run: openssl rand -base64 32
CRON_SECRET=
# Set to 1 once after deploy to populate tours on container start, then optional
CRICKET_SYNC_ON_START=1
# One-time only if cricket_snapshots table is missing, then remove:
# PAYLOAD_SQLITE_PUSH_SCHEMA=1
AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
# DOMAIN=your-domain.com
